# Copiar este archivo como .env y rellenar los valores
APP_ENV=development
APP_PORT=8000

ANTHROPIC_API_KEY=

# Modelo de vision (opcional, default claude-sonnet-4-6)
# VISION_MODEL=claude-opus-4-7

# Lado mas largo al que se redimensiona la imagen antes de enviar (px, default 1800)
# MAX_IMAGE_SIDE=1800

UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
